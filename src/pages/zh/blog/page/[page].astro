---
import { getCollection } from 'astro:content';
import BaseHead from '../../../../components/BaseHead.astro';
import Header from '../../../../components/sections/Header.astro';
import Footer from '../../../../components/sections/Footer.astro';
import BlogHero from '../../../../components/sections/BlogHero.astro';
import BlogAllArticles from '../../../../components/sections/BlogAllArticles.astro';
import BlogPagination from '../../../../components/ui/nav/BlogPagination.astro';

export async function getStaticPaths() {
  const PAGE_SIZE = 6;
  const allPosts = (await getCollection('blog')).sort((a, b) => +b.data.pubDate - +a.data.pubDate);
  // Filter to only show Chinese posts (title contains Chinese characters)
  const posts = allPosts.filter(post => /[\u4e00-\u9fa5]/.test(post.data.title));
  const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
  return Array.from({ length: totalPages - 1 }, (_, i) => ({ params: { page: String(i + 2) } }));
}

const PAGE_SIZE = 6;
const allPosts = (await getCollection('blog')).sort((a, b) => +b.data.pubDate - +a.data.pubDate);
// Filter to only show Chinese posts (title contains Chinese characters)
const posts = allPosts.filter(post => /[\u4e00-\u9fa5]/.test(post.data.title));
const { page } = Astro.params;
const currentPage = Math.max(1, parseInt(page || '1', 10));
const start = (currentPage - 1) * PAGE_SIZE;
const end = start + PAGE_SIZE;
const pagePosts = posts.slice(start, end);
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
---

<html lang="zh-CN" data-theme="light" class="light">
  <head>
    <BaseHead title={`博客 - 第 ${currentPage} 页`} description={`博客第 ${currentPage} 页`} />
    {currentPage > 1 && (
      <link rel="prev" href={currentPage === 2 ? `/zh/blog/` : `/zh/blog/page/${currentPage - 1}/`} />
    )}
    {currentPage < totalPages && (
      <link rel="next" href={`/zh/blog/page/${currentPage + 1}/`} />
    )}
  </head>
  <body>
    <Header />
    <BlogHero title="博客" subtitle="所有工具的使用指南" />
    <main class="mx-auto max-w-6xl px-4 py-8 space-y-10">
      <BlogAllArticles posts={pagePosts} />
      <BlogPagination currentPage={currentPage} totalPages={totalPages} />
    </main>
    <Footer />
  </body>
  </html>
