---
// src/pages/image-gallery.astro
// 图片分页展示页面 - 可直接放在 src/pages 路径下访问

// 图片链接列表（从您的MD中提取）
const imageUrls = [
  "https://image01-1315567783.cos.ap-guangzhou.myqcloud.com/mdnice/2026/07/3eafee08e3e6493323da66108b4b56d.webp?imageSlim",
  "https://image01-1315567783.cos.ap-guangzhou.myqcloud.com/mdnice/2026/07/b65f1db4f4e1cfaa2426297ab565f6c.webp?imageSlim",
  "https://image01-1315567783.cos.ap-guangzhou.myqcloud.com/mdnice/2026/07/3173eb11a6d4ec79160e91806a292e5.webp?imageSlim",
  "https://image01-1315567783.cos.ap-guangzhou.myqcloud.com/mdnice/2026/07/a0a66e9fd6c770496500aead5199c9d.webp?imageSlim",
  "https://image01-1315567783.cos.ap-guangzhou.myqcloud.com/mdnice/2026/07/5c6a8e24d83252ff3d7f79796a7a56e.webp?imageSlim",
  "https://image01-1315567783.cos.ap-guangzhou.myqcloud.com/mdnice/2026/07/e0530011fec7df54a3d5d3a22172d6a.webp?imageSlim",
  "https://image01-1315567783.cos.ap-guangzhou.myqcloud.com/mdnice/2026/07/fc1f9e2da8862f62f04cf7ea1bd03c5.webp?imageSlim",
  "https://image01-1315567783.cos.ap-guangzhou.myqcloud.com/mdnice/2026/07/8ea80aa8db4629ca961ddc2ff7b815c.webp?imageSlim",
